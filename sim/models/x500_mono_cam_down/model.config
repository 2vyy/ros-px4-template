<?xml version="1.0"?>
<model>
  <name>x500_mono_cam_down</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <author>
    <name>ros-px4-template</name>
    <email>noreply@example.com</email>
  </author>
  <description>
    X500 with a downward-facing monocular camera. Repo-local variant of PX4's
    x500_mono_cam_down: same nadir geometry, but the sensor is named 'camera'
    (not 'imager') so it matches _vision_bridge's topic template, and renders at
    640x480 @ 20 Hz (competition-realistic and cheap). Includes PX4's base x500
    and reuses PX4's gz_x500_mono_cam_down airframe (4014). See plans/062.
  </description>
</model>
